{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "dns-list",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-16",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "vars": {
    "AWS_SES_REGION": "sa-east-1",
    "SES_FROM_EMAIL": "domains@ambiente1.com.br",
    "SES_FROM_NAME": "Ambiente1 Domains",
    "FRONTEND_URL": "http://localhost:4321"
  },
  "triggers": {
    "crons": ["0 0 * * *"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "demos",
      "database_id": "bde59a46-2fae-43d2-b2d9-b27373655821",
      "migrations_dir": "migrations"
    }
  ]
}
