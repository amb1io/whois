{
  "name": "domains-reseller",
  "private": true,
  "workspaces": [
    "whois-scheduler",
    "whois-api-search",
    "whois-frontend"
  ],
  "scripts": {
    "dev:whois-scheduler": "npm run dev -w whois-scheduler",
    "dev:whois-api-search": "npm run dev -w whois-api-search",
    "dev:whois-frontend": "npm run dev -w whois-frontend",
    "deploy:whois-scheduler": "npm run deploy -w whois-scheduler",
    "deploy:whois-api-search": "npm run deploy -w whois-api-search",
    "deploy:whois-frontend": "npm run deploy -w whois-frontend",
    "migrate:whois-scheduler:local": "npm run migrate:local -w whois-scheduler",
    "migrate:whois-scheduler:remote": "npm run migrate:remote -w whois-scheduler",
    "migrate:whois-api-search:local": "npm run migrate:local -w whois-api-search",
    "migrate:whois-api-search:remote": "npm run migrate:remote -w whois-api-search"
  }
}
