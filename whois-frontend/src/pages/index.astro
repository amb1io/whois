---
import "../styles/global.css";
import SearchForm from "../components/SearchForm.astro";
import WhoisResults from "../components/WhoisResults.astro";
import Footer from "../components/Footer.astro";

const siteTitle = "Domain Alert";
const siteDescription =
  "Look up WHOIS and RDAP records for domains you care about.";
const siteAuthor = "Rhamses Soares";
const themeColor = "#2563eb";
const searchApiUrl =
  import.meta.env.PUBLIC_DNS_SEARCH_API_URL ?? "http://localhost:8787/search";
---

<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta
      name="viewport"
      content="width=device-width,initial-scale=1,user-scalable=no"
    />
    <meta name="theme-color" content={themeColor} />
    <meta name="description" content={siteDescription} />
    <meta name="author" content={siteAuthor} />
    <meta name="generator" content={Astro.generator} />
    <title>{siteTitle}</title>
    <script src="https://unpkg.com/htmx.org@1.9.12" defer></script>
    <script
      src="https://unpkg.com/htmx.org@1.9.12/dist/ext/json-enc.js"
      defer></script>
    <script src="https://unpkg.com/alpinejs@3.14.1" defer></script>
    <style is:inline>
      #whois-loading {
        display: none;
      }
      #whois-loading.htmx-request {
        display: flex;
      }
      [x-cloak] {
        display: none !important;
      }
    </style>
  </head>
  <body class="flex min-h-screen flex-col bg-slate-100 text-slate-900">
    <main class="flex flex-1 flex-col items-center justify-center px-4 pt-8">
      <div
        class="flex w-full max-w-3xl flex-col items-center gap-8 text-center"
      >
        <h1
          class="text-4xl font-semibold tracking-tight text-slate-900 sm:text-6xl"
        >
          Domain <span class="text-blue-600">Alert</span>
        </h1>
        <p class="text-base text-slate-600 sm:text-lg">
          Search domain registration details, nameservers, and expiration dates.
        </p>
        <SearchForm searchApiUrl={searchApiUrl} />
        <section
          class="flex w-full max-w-2xl flex-col items-stretch gap-4 text-left"
          x-data="domainSearch()"
          x-on:domain-search:start.window="onSearchStart()"
          x-on:domain-search:complete.window="onSearchComplete($event)"
        >
          <WhoisResults />
          <div
            id="whois-loading"
            class="mt-2 text-sm text-slate-600"
            role="status"
            aria-live="polite"
          >
            Fetching WHOIS details...
          </div>
        </section>
      </div>
    </main>

    <Footer />

    <script is:inline>
      document.addEventListener("alpine:init", () => {
        Alpine.data("domainSearch", () => ({
          searchedDomain: "",
          rows: [],
          error: null,
          get hasResults() {
            return this.rows.length > 0;
          },
          get quotedDomain() {
            return this.searchedDomain ? `"${this.searchedDomain}"` : "";
          },
          onSearchStart() {
            this.error = null;
            this.rows = [];
          },
          onSearchComplete(event) {
            const htmxEvent = event.detail;
            const xhr = htmxEvent?.detail?.xhr;
            if (!xhr) {
              this.error = "Unexpected search response.";
              return;
            }

            if (xhr.status === 200) {
              try {
                const data = JSON.parse(xhr.responseText);
                const input = document.getElementById("domain-search-input");
                this.searchedDomain =
                  data.ldhName ||
                  data.unicodeName ||
                  (input instanceof HTMLInputElement ? input.value : "");
                this.rows = parseRdapRows(data);
                this.error = null;
              } catch {
                this.error = "Unable to parse RDAP response.";
                this.rows = [];
              }
              return;
            }

            this.rows = [];
            try {
              const payload = JSON.parse(xhr.responseText);
              this.error =
                payload.error ||
                payload.description?.join?.(" ") ||
                payload.title ||
                `Request failed (${xhr.status})`;
            } catch {
              this.error = xhr.responseText || `Request failed (${xhr.status})`;
            }
          },
        }));
      });

      function formatDate(value) {
        if (!value) return "—";
        const date = new Date(value);
        if (Number.isNaN(date.valueOf())) return String(value);
        return new Intl.DateTimeFormat(undefined, {
          dateStyle: "medium",
          timeStyle: "short",
        }).format(date);
      }

      function vcardField(entity, fieldName) {
        const vcard = entity?.vcardArray?.[1];
        if (!Array.isArray(vcard)) return null;
        const entry = vcard.find((item) => item[0] === fieldName);
        return entry?.[3] ?? null;
      }

      function parseRdapRows(data) {
        if (data.source === "whois") {
          return [
            { label: "Domain", value: data.ldhName || "—", pre: false },
            {
              label: "Updated At",
              value: formatDate(data.updatedDate),
              pre: false,
            },
            {
              label: "Expires At",
              value: formatDate(data.expiryDate),
              pre: false,
            },
            { label: "WHOIS", value: data.whoisText || "—", pre: true },
          ];
        }

        const registrar = (data.entities || []).find((entity) =>
          (entity.roles || []).includes("registrar")
        );
        const registrarName = registrar ? vcardField(registrar, "fn") : null;
        const registrarId =
          registrar?.publicIds?.find((id) =>
            String(id.type || "").includes("Registrar")
          )?.identifier ?? null;
        const events = data.events || [];
        const eventDate = (action) =>
          events.find((event) => event.eventAction === action)?.eventDate;
        const nameservers = (data.nameservers || [])
          .map((ns) => ns.unicodeName || ns.ldhName)
          .filter(Boolean);

        return [
          { label: "Domain", value: data.unicodeName || data.ldhName || "—" },
          { label: "Handle", value: data.handle || "—" },
          { label: "Registrar", value: registrarName || "—" },
          { label: "Registrar ID", value: registrarId || "—" },
          {
            label: "Statuses",
            value: (data.status || []).join(", ") || "—",
          },
          {
            label: "Nameservers",
            value: nameservers.join(", ") || "—",
          },
          {
            label: "Created At",
            value: formatDate(eventDate("registration")),
          },
          {
            label: "Updated At",
            value: formatDate(eventDate("last changed")),
          },
          {
            label: "Expires At",
            value: formatDate(eventDate("expiration")),
          },
          {
            label: "DNSSEC",
            value:
              data.secureDNS?.delegationSigned === true ? "Signed" : "Unsigned",
          },
        ];
      }

      function runQueryParamSearch() {
        const domain = new URLSearchParams(window.location.search).get("q")?.trim();
        if (!domain) {
          return;
        }

        const input = document.getElementById("domain-search-input");
        const form = document.getElementById("domain-search-form");
        if (!(input instanceof HTMLInputElement) || !(form instanceof HTMLFormElement)) {
          return;
        }

        input.value = domain;
        window.dispatchEvent(new CustomEvent("domain-search:start"));
        form.requestSubmit();

        const cleanUrl = new URL(window.location.href);
        cleanUrl.searchParams.delete("q");
        history.replaceState({}, "", cleanUrl);
      }

      window.addEventListener("load", runQueryParamSearch);
    </script>
  </body>
</html>
