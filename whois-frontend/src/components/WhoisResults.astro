---
---

<div
  x-show="hasResults || error"
  x-cloak
  class="w-full max-w-2xl space-y-4 text-left"
>
  <template x-if="error">
    <div
      class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700 shadow-sm"
      x-text="error"
    ></div>
  </template>

      <template x-if="hasResults">
    <div class="space-y-4 rounded-lg border border-slate-200 bg-white px-4 py-3 text-sm text-slate-600 shadow-sm">
      <div class="rounded-lg border border-blue-200 bg-blue-50 px-4 py-3 text-sm text-blue-700 shadow-sm">
        <p>
          Latest lookup for
          <span class="font-semibold text-blue-900" x-text="quotedDomain"></span>.
        </p>
      </div>
      <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
        <table class="min-w-full divide-y divide-slate-200 text-sm">
          <tbody class="divide-y divide-slate-200">
            <template x-for="row in rows" :key="row.label">
              <tr>
                <th
                  class="w-40 bg-slate-50 px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500"
                  x-text="row.label"
                ></th>
                <td
                  class="px-4 py-3 text-sm text-slate-800"
                  :class="row.pre ? 'whitespace-pre-wrap font-mono text-xs' : ''"
                  x-text="row.value"
                ></td>
              </tr>
            </template>
          </tbody>
        </table>
      </div>
    </div>
  </template>
</div>
